# FeedbackCollector Environment Configuration
# Copy this file to .env and fill in your credentials.
# The variable names below are exactly what src/config.py reads.

# Flask Configuration
FLASK_SECRET_KEY=your-secure-random-key-here
FLASK_DEBUG=0
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# Reddit API Credentials (https://www.reddit.com/prefs/apps)
# Without these, Reddit collection is silently skipped at runtime.
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=FeedbackCollector/1.0

# GitHub Personal Access Token (https://github.com/settings/tokens)
# Required for GitHub Discussions and GitHub Issues collectors.
# Public-repo read scope is sufficient. Without it both collectors
# return 0 items.
GITHUB_TOKEN=your_github_pat_here

# Azure DevOps (https://dev.azure.com/<org>/_usersSettings/tokens)
# All four are required for the ADO collector. ADO_ORG_URL must be the
# full URL, e.g. https://dev.azure.com/myorg
ADO_PAT=your_azure_devops_pat_token
ADO_ORG_URL=https://dev.azure.com/your_organization
ADO_PROJECT_NAME=your_project_name
ADO_PARENT_WORK_ITEM_ID=12345

# Microsoft Fabric SQL Database (Optional - bulk write only)
FABRIC_SQL_SERVER=your-fabric-instance.database.windows.net
FABRIC_SQL_DATABASE=your_database_name
FABRIC_SQL_AUTHENTICATION=ActiveDirectoryInteractive

# Microsoft Fabric Lakehouse (Optional - bulk write only)
FABRIC_LIVY_ENDPOINT=https://your-workspace.fabric.microsoft.com/api/
FABRIC_TARGET_TABLE_NAME=feedback
FABRIC_WRITE_MODE=append

# Application Settings
MAX_ITEMS_PER_RUN=100
DEFAULT_STATUS=New
SYSTEM_USER=FeedbackCollector
